{
  "name": "opencowork",
  "version": "0.10.3",
  "description": "AI Native Desktop Agent - OpenCowork",
  "main": "dist/main/main/index.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "clean:src": "find src -name '*.js' -type f ! -name '*.test.js' -delete",
    "build:main": "npm run clean:src && tsc -p tsconfig.main.json",
    "build:preload": "npm run clean:src && tsc -p tsconfig.preload.json",
    "build:renderer": "npm run clean:src && vite build",
    "electron:dev": "npm run build:main && npm run build:preload && npm run build:renderer && electron .",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "prepare": "npm run build:main && npm run build:preload",
    "postversion": "node -e \"const pkg=require('./package.json'); const fs=require('fs'); let doc=fs.readFileSync('docs/USER_GUIDE.md','utf-8'); doc=doc.replace(/_OpenCowork v[\\\\d.]+_/g, '_OpenCowork v'+pkg.version+'_'); doc=doc.replace(/\\\\| 版本     \\| v[\\\\d.]+       \\|/g, '| 版本     | v'+pkg.version+'       |'); doc=doc.replace(/更新日期 \\| \\\\d{4}-\\\\d{2}-\\\\d{2}/g, '更新日期 | '+new Date().toISOString().split('T')[0].replace(/-/g,'-')); fs.writeFileSync('docs/USER_GUIDE.md',doc);\""
  },
  "keywords": [
    "ai",
    "agent",
    "desktop",
    "electron",
    "browser-automation"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@langchain/core": "latest",
    "@langchain/langgraph": "latest",
    "@langchain/langgraph-checkpoint-sqlite": "latest",
    "@langchain/openai": "latest",
    "@larksuiteoapi/node-sdk": "^1.36.0",
    "axios": "^1.14.0",
    "better-sqlite3": "^12.8.0",
    "js-yaml": "^4.1.1",
    "node-cron": "^4.2.1",
    "playwright-extra": "^4.3.6",
    "playwright-stealth": "^0.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "turndown": "^7.2.2",
    "ws": "^8.20.0",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@testing-library/jest-dom": "^6.4.8",
    "@testing-library/react": "^14.3.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.0",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/turndown": "^5.0.6",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.34.3",
    "jsdom": "^24.1.0",
    "playwright": "^1.44.1",
    "postcss": "^8.4.38",
    "prettier": "^3.3.2",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.4.5",
    "vite": "^5.3.1",
    "vitest": "^1.6.0"
  },
  "build": {
    "appId": "com.opencowork.app",
    "productName": "OpenCowork",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    },
    "windows": {
      "target": "nsis"
    }
  }
}
