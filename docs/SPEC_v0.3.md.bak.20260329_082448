#### 4.1.2 Selectorдјҳе…Ҳзә§fallbackй“ҫпјҲзҒөжҙ»и®ҫи®Ўпјү

```typescript
const SELECTOR_PRIORITY_CHAIN = [
  "data-testid", // дјҳе…Ҳзә§1: жөӢиҜ•IDпјҲжңҖзЁіе®ҡпјү
  "id", // дјҳе…Ҳзә§2: IDпјҲйңҖе”ҜдёҖжҖ§жЈҖжҹҘпјү
  "aria-label", // дјҳе…Ҳзә§3: ж— йҡңзўҚж Үзӯҫ
  "name", // дјҳе…Ҳзә§4: nameеұһжҖ§
  "role+text", // дјҳе…Ҳзә§5: role+ж–Үжң¬з»„еҗҲ
  "css-path", // дјҳе…Ҳзә§6: зӣёеҜ№CSSи·Ҝеҫ„пјҲжңҖеҗҺж–№жЎҲпјү
] as const;

function buildSelector(
  el: Element,
): { selector: string; priority: number } | null {
  // 1. data-testid
  if (el.dataset.testid) {
    return { selector: `[data-testid="${el.dataset.testid}"]`, priority: 1 };
  }

  // 2. id (йңҖиҰҒе”ҜдёҖжҖ§жЈҖжҹҘ)
  if (el.id && document.querySelectorAll(`#${el.id}`).length === 1) {
    return { selector: `#${el.id}`, priority: 2 };
  }

  // 3. aria-label
  const ariaLabel = el.getAttribute("aria-label");
  if (ariaLabel && ariaLabel.trim().length > 0) {
    const role = el.getAttribute("role") || el.tagName.toLowerCase();
    return {
      selector: `[role="${role}"][aria-label="${ariaLabel}"]`,
      priority: 3,
    };
  }

  // 4. nameеұһжҖ§
  const name = el.getAttribute("name");
  if (name) {
    return { selector: `[name="${name}"]`, priority: 4 };
  }

  // 5. role + text
  const role = el.getAttribute("role");
  const text = el.innerText?.trim();
  if (role && text) {
    return { selector: `[role="${role}"]`, priority: 5 };
  }

  // 6. CSS path (жңҖеҗҺж–№жЎҲ)
  return { selector: generateRelCSSPath(el), priority: 6 };
}
